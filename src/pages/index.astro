---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import Badge from '../components/ui/Badge.astro';
import Card from '../components/ui/Card.astro';
import CardContent from '../components/ui/CardContent.astro';

// SEO optimized page data
const pageTitle = "Renata Horvat - Designer & Digital Creator | Science Communication Expert Croatia";
const pageDescription = "Renata Horvat is a Croatian designer specializing in science communication, e-learning platforms, and academic websites. 20+ years transforming complex research into engaging visual experiences for universities and research institutions.";
const pageKeywords = "designer Croatia, science communication, e-learning design, academic websites, visual design, instructional design, educational design, scientific visualization, infographics, digital creator, web design Croatia, university websites, research communication, Zagreb designer";
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
  keywords={pageKeywords}
>
  <Header />
  <!-- Content: Layout.astro already wraps slot in <main id="main-content">; no duplicate main here -->
  <>
    <Hero />

    <!-- What I Do Section -->
    <section class="py-20 bg-transparent">
      <div class="relative max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <Badge variant="default" class="gap-2 mb-6">
            <span class="w-2 h-2 bg-cyan-400 rounded-full"></span>
            What I Do
          </Badge>
          <h2 class="text-4xl lg:text-5xl font-black text-white mb-6">
            <span class="bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 bg-clip-text text-transparent">
              Web design and development
            </span>
          </h2>
          <p class="text-xl text-gray-300 leading-relaxed max-w-3xl mx-auto">
            I design and build clear, maintainable websites for organizations, projects, and small teams.
          </p>
        </div>

        <!-- Three Service Areas - Simple Cards -->
        <div class="grid lg:grid-cols-3 gap-8 mb-16">
          <!-- Digital platforms -->
          <Card class="bg-gray-900/60 border border-blue-400/20 hover:border-blue-400/40 transition-all duration-300">
            <CardContent class="p-8 text-center">
              <div class="w-14 h-14 bg-gradient-to-r from-blue-500 to-purple-600 rounded-xl flex items-center justify-center mb-6 mx-auto">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">Digital platforms</h3>
              <p class="text-gray-300 leading-relaxed mb-4">
                Academic websites, e-learning and conference platforms — structured and built to stay maintainable.
              </p>
              <div class="text-sm text-blue-400 font-semibold">
                Clarity, performance, long-term usability
              </div>
            </CardContent>
          </Card>

          <!-- Content & communication -->
          <Card class="bg-gray-900/60 border border-cyan-400/20 hover:border-cyan-400/40 transition-all duration-300">
            <CardContent class="p-8 text-center">
              <div class="w-14 h-14 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-xl flex items-center justify-center mb-6 mx-auto">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">Content & communication</h3>
              <p class="text-gray-300 leading-relaxed mb-4">
                Clear structure, readable content, and visual systems that help people understand, navigate, and trust what they're seeing — especially when the subject matter is complex.
              </p>
              <div class="text-sm text-cyan-400 font-semibold">
                Structure that supports understanding
              </div>
            </CardContent>
          </Card>

          <!-- Long-term support -->
          <Card class="bg-gray-900/60 border border-purple-400/20 hover:border-purple-400/40 transition-all duration-300">
            <CardContent class="p-8 text-center">
              <div class="w-14 h-14 bg-gradient-to-r from-purple-600 to-pink-500 rounded-xl flex items-center justify-center mb-6 mx-auto">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-3">Long-term support</h3>
              <p class="text-gray-300 leading-relaxed mb-4">
                Projects built to last. Clean, maintainable systems that are easy to update, adapt, and grow over time — without constant technical headaches.
              </p>
              <div class="text-sm text-purple-400 font-semibold">
                Easy to update and grow
              </div>
            </CardContent>
          </Card>
        </div>

        <div class="text-center mb-10">
          <h2 class="text-4xl lg:text-5xl font-black text-white">
            <span class="bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 bg-clip-text text-transparent">
              Built to last, not just to launch
            </span>
          </h2>
        </div>

        <!-- Stats -->
        <div class="max-w-5xl mx-auto mb-16">
          <div class="relative gpu-accelerated">
            <div class="absolute -inset-1 bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 rounded-2xl blur-sm opacity-20"></div>
            <Card class="relative bg-gray-900/90 border border-cyan-400/20 gpu-accelerated">
              <CardContent class="p-8 lg:p-12">
                <div class="grid md:grid-cols-3 gap-8 text-center">
                  <div>
                    <div class="text-4xl lg:text-5xl font-black bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent mb-2">
                      20+
                    </div>
                    <div class="text-gray-300 font-medium">Years of Experience</div>
                    <div class="text-sm text-gray-400 mt-1">Working with academic and research teams</div>
                  </div>
                  <div>
                    <div class="text-4xl lg:text-5xl font-black bg-gradient-to-r from-blue-500 to-purple-600 bg-clip-text text-transparent mb-2">
                      50+
                    </div>
                    <div class="text-gray-300 font-medium">Projects Delivered</div>
                    <div class="text-sm text-gray-400 mt-1">Academic websites, e-learning, and research platforms</div>
                  </div>
                  <div>
                    <div class="text-4xl lg:text-5xl font-black bg-gradient-to-r from-purple-600 to-pink-500 bg-clip-text text-transparent mb-2">
                      15+
                    </div>
                    <div class="text-gray-300 font-medium">Universities & Institutions</div>
                    <div class="text-sm text-gray-400 mt-1">Ongoing and long-term collaborations</div>
                  </div>
                </div>
                <div class="mt-10 pt-8 border-t border-gray-700">
                  <div class="text-center">
                    <p class="text-gray-400 text-sm uppercase tracking-wider mb-4">Trusted by</p>
                    <p class="text-gray-300 text-lg leading-relaxed">
                      <span class="text-cyan-400 font-semibold">University of Zagreb</span> •
                      Croatian Botanical Society •
                      Croatian Biological Society •
                      FEPS Europe •
                      and other academic and research organizations
                    </p>
                  </div>
                </div>
              </CardContent>
            </Card>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="text-center">
          <a 
            href="/services" 
            class="inline-block px-10 py-5 bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-bold text-xl rounded-2xl hover:from-cyan-600 hover:to-blue-700 transition-all duration-300 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2 focus:ring-offset-gray-900"
            onclick="if(typeof window.gtag !== 'undefined') window.gtag('event', 'cta_click', { cta_type: 'view_portfolio', cta_location: 'homepage' })"
          >
            Explore Selected Projects →
          </a>
        </div>
      </div>
    </section>
  </>
  <Footer />
</Layout>