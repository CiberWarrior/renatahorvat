---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Badge from "../components/ui/Badge.astro";
import Card from "../components/ui/Card.astro";
import CardContent from "../components/ui/CardContent.astro";

// SEO optimized page data
const pageTitle = "Contact Renata Horvat - Croatian Designer & Science Communication Expert";
const pageDescription = "Get in touch with Renata Horvat for your next design project. Specializing in academic websites, e-learning platforms, and scientific visual content. Based in Zagreb, Croatia.";
const pageKeywords = "contact Renata Horvat, Croatian designer, Zagreb designer, science communication expert, academic web design, e-learning consultant, instructional design services, research visualization, educational design Croatia";

// Structured data for contact page
const contactStructuredData = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Renata Horvat",
  "description": pageDescription,
  "url": "https://renatahorvat.com/contact",
  "mainEntity": {
    "@type": "Person",
    "name": "Renata Horvat",
    "email": "screatives.info@gmail.com",
    "jobTitle": "Designer & Digital Creator",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Zagreb",
      "addressCountry": "HR"
    }
  }
};

const contactBreadcrumbs = [
  { name: "Home", url: "https://renatahorvat.com" },
  { name: "Contact", url: "https://renatahorvat.com/contact" }
];
---

<Layout 
  title={pageTitle} 
  description={pageDescription}
  keywords={pageKeywords}
  structuredData={contactStructuredData}
  breadcrumbs={contactBreadcrumbs}
  preloadResources={[{ href: '/images/renatahorvat.jpg', as: 'image', type: 'image/jpeg' }]}
>
  <Header />
  
  <div class="relative">
    <!-- Space Background -->
    <div class="fixed inset-0 space-background">
      <!-- Subtle overlay to keep focus on the form -->
      <div class="absolute inset-0 bg-slate-950/70"></div>
      <!-- Nebula effect -->
      <div class="absolute inset-0 nebula-1 opacity-60"></div>
      <div class="absolute inset-0 nebula-2 opacity-50"></div>
      
      <!-- Rocket silhouette -->
      <div class="absolute top-1/4 right-1/4 rocket-silhouette opacity-60 blur-[1px]">
        <svg class="w-16 h-16 text-white/3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 2L13.5 8.5L20 9L13.5 9.5L12 16L10.5 9.5L4 9L10.5 8.5L12 2Z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10 16L8 20L12 18L16 20L14 16"/>
        </svg>
      </div>
      
      <!-- Second rocket silhouette -->
      <div class="absolute bottom-1/3 left-1/4 rocket-silhouette-2 opacity-60 blur-[1px]">
        <svg class="w-12 h-12 text-white/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 2L13.5 8.5L20 9L13.5 9.5L12 16L10.5 9.5L4 9L10.5 8.5L12 2Z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10 16L8 20L12 18L16 20L14 16"/>
        </svg>
      </div>
    </div>
    
    <!-- Hero Section -->
    <section class="relative z-10 bg-transparent pt-10 pb-6 lg:pt-20 lg:pb-10">
      <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-12 lg:mb-16 reveal">
          <!-- Heading -->
          <div class="text-center mb-10 lg:mb-14">
            <h1 class="text-[40px] lg:text-[70px] xl:text-[88px] font-black text-white mb-4 leading-tight">
              <span class="bg-gradient-to-r from-cyan-300 via-blue-400 to-cyan-400 bg-clip-text text-transparent">
                Let's talk about your project
              </span>
            </h1>
            <p class="text-lg lg:text-xl text-cyan-200/80 font-medium tracking-wide">
              Renata Horvat — Designer & Digital Creator
            </p>
          </div>
          
          <!-- Stylized Text Section -->
          <div class="text-center space-y-4 lg:space-y-6 max-w-5xl mx-auto reveal">
            <p class="text-xl lg:text-4xl xl:text-5xl text-gray-50 font-semibold leading-relaxed tracking-tight">
              You don't need a fully formed brief to get in touch.
            </p>
            <p class="text-base lg:text-2xl text-gray-300 font-medium">
              If you're thinking about a project, exploring an idea, or just want to talk things through before building anything, feel free to send a message.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form Section -->
    <section class="relative z-10 bg-transparent pt-0 pb-16">
      <div class="relative max-w-3xl mx-auto px-6 lg:px-8">
        <!-- Form Container -->
        <div class="relative group">
          <!-- Neon glow effect -->
          <div class="absolute -inset-1 bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 rounded-2xl blur opacity-15"></div>
          
          <!-- Main form card -->
          <div class="relative bg-gray-900/80 backdrop-blur-xl border border-cyan-400/30 rounded-2xl overflow-hidden">
            <div class="p-8 lg:p-10">
              <!-- Form Header -->
              <div class="text-center mb-8">
                <div class="flex items-center justify-center gap-3 mb-4">
                  <div class="rounded-full p-[2px] bg-gradient-to-r from-cyan-400/80 via-blue-500/80 to-purple-500/80 flex-shrink-0">
                    <img
                      src="/images/renatahorvat.jpg"
                      alt="Renata Horvat"
                      width="48"
                      height="48"
                      loading="eager"
                      decoding="async"
                      class="w-12 h-12 rounded-full object-cover block"
                    />
                  </div>
                  <h2 class="text-3xl font-bold bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 bg-clip-text text-transparent">
                    Send Me a Message
                  </h2>
                </div>
                <p class="text-gray-300">
                  Fill out the form below and I'll get back to you within 24 hours.
                </p>
              </div>

              <!-- Success Message (hidden by default) -->
              <div id="success-message" class="hidden mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-xl">
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <div>
                    <h3 class="text-green-400 font-semibold mb-1">Message sent successfully!</h3>
                    <p class="text-green-300 text-sm">Thank you for contacting me. I'll get back to you soon!</p>
                  </div>
                </div>
              </div>

              <!-- Error Message (hidden by default) -->
              <div id="error-message" class="hidden mb-6 p-4 bg-red-500/10 border border-red-500/30 rounded-xl">
                <div class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-red-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <div>
                    <h3 class="text-red-400 font-semibold mb-1">Oops! Something went wrong</h3>
                    <p class="text-red-300 text-sm" id="error-text">Please try again or send me an email at screatives.info@gmail.com</p>
                  </div>
                </div>
              </div>

              <!-- Contact Form -->
              <form 
                id="contact-form"
                class="space-y-6"
                novalidate
              >
                <!-- Name and Surname Field -->
                <div class="form-field-group">
                  <label for="name" class="block text-sm font-semibold text-gray-300 mb-2">
                    Your name <span class="text-red-400">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                    </div>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      autocomplete="name"
                      class="w-full pl-12 pr-4 py-3 bg-gray-800/50 border border-gray-600/50 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:border-cyan-400 transition-all duration-300"
                      placeholder="e.g. Ime i Prezime"
                      aria-describedby="name-error"
                    />
                    <div id="name-error" class="hidden mt-1 text-sm text-red-400" role="alert"></div>
                  </div>
                </div>

                <!-- Email Field -->
                <div class="form-field-group">
                  <label for="email" class="block text-sm font-semibold text-gray-300 mb-2">
                    Email <span class="text-red-400">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                      </svg>
                    </div>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      autocomplete="email"
                      class="w-full pl-12 pr-4 py-3 bg-gray-800/50 border border-gray-600/50 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:border-cyan-400 transition-all duration-300"
                      placeholder="your.email@example.com"
                      aria-describedby="email-error"
                    />
                    <div id="email-error" class="hidden mt-1 text-sm text-red-400" role="alert"></div>
                  </div>
                </div>

                <!-- Project Type Field -->
                <div class="form-field-group">
                  <label class="block text-sm font-semibold text-gray-300 mb-3">
                    What kind of project is it?
                    <span class="text-gray-500 font-normal ml-1">(optional)</span>
                  </label>
                  <input type="hidden" id="project-type" name="project_type" value="" />
                  <div class="flex flex-wrap gap-2" role="group" aria-label="Project type">
                    {['Website', 'E-learning', 'Scientific visual', 'Infographic', 'Not sure yet'].map((tag) => (
                      <button
                        type="button"
                        class="project-tag px-4 py-2 rounded-xl border border-gray-700/40 bg-gray-900/30 text-gray-300 text-sm font-medium hover:border-cyan-400/50 hover:bg-cyan-400/10 transition-all duration-200"
                        data-value={tag}
                      >
                        {tag}
                      </button>
                    ))}
                  </div>
                </div>

                <!-- Message Field -->
                <div class="form-field-group">
                  <div class="flex items-center justify-between mb-2">
                    <label for="message" class="block text-sm font-semibold text-gray-300">
                      Message <span class="text-red-400">*</span>
                    </label>
                    <span id="message-counter" class="text-xs text-gray-400">0 / 1000</span>
                  </div>
                  <div class="relative">
                    <div class="absolute left-4 top-4 text-gray-400 pointer-events-none">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                      </svg>
                    </div>
                    <textarea
                      id="message"
                      name="message"
                      maxlength="1000"
                      rows="6"
                      class="w-full pl-12 pr-4 py-3 bg-gray-800/50 border border-gray-600/50 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cyan-400/50 focus:border-cyan-400 transition-all duration-300 resize-none"
                      placeholder="Tell me what you're thinking about — even if it's just an idea."
                      aria-describedby="message-error"
                    ></textarea>
                    <div id="message-error" class="hidden mt-1 text-sm text-red-400" role="alert"></div>
                  </div>
                </div>

                <!-- GDPR Consent Checkbox -->
                <div class="form-field-group">
                  <div class="flex items-start gap-3 p-4 bg-purple-500/10 border border-purple-500/20 rounded-xl">
                    <input
                      type="checkbox"
                      id="gdpr-consent"
                      name="gdpr_consent"
                      class="mt-1 w-4 h-4 rounded border-gray-600 text-cyan-500 focus:ring-cyan-500 focus:ring-offset-gray-900"
                    />
                    <label for="gdpr-consent" class="text-sm text-gray-300 leading-relaxed">
                      I agree to the processing of my personal data according to the 
                      <a href="/privacy-policy" target="_blank" class="text-cyan-400 hover:text-cyan-300 underline">Privacy Policy</a>. 
                      Your information will only be used to respond to your inquiry. <span class="text-red-400">*</span>
                    </label>
                  </div>
                  <div id="gdpr-error" class="hidden mt-2 text-sm text-red-400" role="alert"></div>
                </div>

                <!-- Honeypot (spam protection - hidden field) -->
                <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

                <!-- Submit Button -->
                <button
                  type="submit"
                  id="submit-button"
                  class="group w-full inline-grid items-center justify-center px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-bold text-lg rounded-xl hover:from-cyan-600 hover:to-blue-700 transition-all duration-300 shadow-lg shadow-cyan-950/20 hover:shadow-cyan-500/20 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none overflow-hidden"
                >
                  <span id="button-text" class="[grid-area:1/1] transition-all duration-300 group-hover:opacity-0 group-hover:-translate-y-4">
                    Send it →
                  </span>
                  <span class="[grid-area:1/1] transition-all duration-300 opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0">
                    On its way! 🚀
                  </span>
                  <span id="button-loader" class="hidden [grid-area:1/1]">
                    <svg class="animate-spin inline-block w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Sending...
                  </span>
                </button>

                <!-- Alternative contact -->
                <div class="mt-6 pt-6 border-t border-gray-700/50">
                  <p class="text-center text-sm text-gray-400 mb-3">Prefer a different channel?</p>
                  <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
                    <a
                      href="mailto:screatives.info@gmail.com"
                      class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-600/50 text-gray-300 hover:border-cyan-400/50 hover:text-cyan-300 transition-all duration-200 text-sm"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                      </svg>
                      screatives.info@gmail.com
                    </a>
                  </div>
                </div>
              </form>
            </div>

            <!-- Decorative elements -->
            <div class="absolute top-4 right-4 w-8 h-8 border-t-2 border-r-2 border-cyan-400/30 rounded-tr-lg"></div>
            <div class="absolute bottom-4 left-4 w-8 h-8 border-b-2 border-l-2 border-cyan-400/30 rounded-bl-lg"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Info Section -->
    <section class="py-12 bg-transparent relative z-10">
      <div class="relative max-w-4xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-6">
          <!-- Response Time Card -->
          <div class="relative group h-full reveal">
            <div class="absolute -inset-1 bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 rounded-2xl blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
            <Card class="relative bg-gray-900/80 backdrop-blur-xl border border-cyan-400/30 rounded-2xl overflow-hidden h-full">
              <CardContent class="p-6 h-full flex flex-col">
                <div class="flex items-start space-x-4 flex-grow">
                  <!-- Icon -->
                  <div class="relative">
                    <div class="w-12 h-12 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-cyan-400/30">
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                    </div>
                    <!-- Icon glow -->
                    <div class="absolute inset-0 w-12 h-12 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-xl blur opacity-30"></div>
                  </div>
                  
                  <div class="flex-1">
                    <h3 class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent mb-2">
                      Response time
                    </h3>
                    <p class="text-gray-100 mb-2 leading-relaxed">
                      I'll reply within a day or two — no auto-responses, just me.
                    </p>
                  </div>
                </div>
                
                <!-- Decorative elements -->
                <div class="absolute top-4 right-4 w-6 h-6 border-t-2 border-r-2 border-cyan-400/30 rounded-tr-lg"></div>
                <div class="absolute bottom-4 left-4 w-6 h-6 border-b-2 border-l-2 border-cyan-400/30 rounded-bl-lg"></div>
              </CardContent>
            </Card>
          </div>

          <!-- Free Consultation Card -->
          <div class="relative group h-full">
            <div class="absolute -inset-1 bg-gradient-to-r from-cyan-400 via-blue-500 to-purple-600 rounded-2xl blur opacity-25"></div>
            <Card class="relative bg-gray-900/80 backdrop-blur-xl border border-cyan-400/30 rounded-2xl overflow-hidden h-full">
              <CardContent class="p-6 h-full flex flex-col">
                <div class="flex items-start space-x-4 flex-grow">
                  <!-- Icon -->
                  <div class="relative">
                    <div class="w-12 h-12 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-cyan-400/30">
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                    </div>
                    <!-- Icon glow -->
                    <div class="absolute inset-0 w-12 h-12 bg-gradient-to-r from-cyan-400 to-blue-500 rounded-xl blur opacity-30"></div>
                  </div>
                  
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      <h3 class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
                        First conversation
                      </h3>
                      <span class="px-2 py-0.5 text-xs font-bold bg-cyan-400/15 text-cyan-300 border border-cyan-400/30 rounded-full">Free</span>
                    </div>
                    <p class="text-gray-100 mb-2 leading-relaxed">
                      A relaxed chat to see if we click — no commitment, no pitch deck required.
                    </p>
                  </div>
                </div>
                
                <!-- Decorative elements -->
                <div class="absolute top-4 right-4 w-6 h-6 border-t-2 border-r-2 border-cyan-400/30 rounded-tr-lg"></div>
                <div class="absolute bottom-4 left-4 w-6 h-6 border-b-2 border-l-2 border-cyan-400/30 rounded-bl-lg"></div>
              </CardContent>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Form Handling Script -->
    <script>
      declare global {
        interface Window {
          gtag?: (...args: unknown[]) => void;
        }
      }

      document.addEventListener('DOMContentLoaded', function () {
        // Typed element references
        const form = document.getElementById('contact-form') as HTMLFormElement | null;
        const submitButton = document.getElementById('submit-button') as HTMLButtonElement | null;
        const buttonText = document.getElementById('button-text') as HTMLElement | null;
        const buttonLoader = document.getElementById('button-loader') as HTMLElement | null;
        const successMessage = document.getElementById('success-message') as HTMLElement | null;
        const errorMessage = document.getElementById('error-message') as HTMLElement | null;
        const errorText = document.getElementById('error-text') as HTMLElement | null;
        const nameInput = document.getElementById('name') as HTMLInputElement | null;
        const emailInput = document.getElementById('email') as HTMLInputElement | null;
        const messageInput = document.getElementById('message') as HTMLTextAreaElement | null;
        const nameError = document.getElementById('name-error') as HTMLElement | null;
        const emailError = document.getElementById('email-error') as HTMLElement | null;
        const messageError = document.getElementById('message-error') as HTMLElement | null;
        const gdprError = document.getElementById('gdpr-error') as HTMLElement | null;
        const gdprCheckbox = document.getElementById('gdpr-consent') as HTMLInputElement | null;
        const messageCounter = document.getElementById('message-counter') as HTMLElement | null;

        if (!form || !submitButton) return;

        // Project type tag selection
        const projectTypeTags = document.querySelectorAll<HTMLButtonElement>('.project-tag');
        const projectTypeInput = document.getElementById('project-type') as HTMLInputElement | null;

        projectTypeTags.forEach((tag) => {
          tag.addEventListener('click', () => {
            const isActive = tag.classList.contains('tag-active');
            projectTypeTags.forEach((t) => {
              t.classList.remove('tag-active', 'border-cyan-400', 'bg-cyan-400/10', 'text-cyan-300');
              t.classList.add('border-gray-600/50', 'bg-gray-800/50', 'text-gray-300');
            });
            if (!isActive) {
              tag.classList.add('tag-active', 'border-cyan-400', 'bg-cyan-400/10', 'text-cyan-300');
              tag.classList.remove('border-gray-600/50', 'bg-gray-800/50', 'text-gray-300');
              if (projectTypeInput) projectTypeInput.value = tag.dataset.value || '';
            } else {
              if (projectTypeInput) projectTypeInput.value = '';
            }
          });
        });

        // Validation functions
        const validateName = (value: string): string => {
          if (!value || !value.trim()) {
            return 'Name is required.';
          }
          if (value.trim().length < 2) {
            return 'Name must be at least 2 characters long.';
          }
          return '';
        };

        const validateEmail = (value: string): string => {
          if (!value || !value.trim()) {
            return 'Email is required.';
          }
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailRegex.test(value)) {
            return 'Please enter a valid email address (e.g., example@domain.com).';
          }
          return '';
        };

        const validateMessage = (value: string): string => {
          if (!value || !value.trim()) {
            return 'Message is required.';
          }
          if (value.trim().length < 10) {
            return 'Message must be at least 10 characters long.';
          }
          if (value.length > 1000) {
            return 'Message cannot exceed 1000 characters.';
          }
          return '';
        };

        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          e.stopPropagation();

          const formData = new FormData(form);

          // Honeypot check — silent reject
          if (formData.get('_gotcha')) return;

          const nameValue = formData.get('name');
          const emailValue = formData.get('email');
          const messageValue = formData.get('message');
          const name = nameValue ? String(nameValue) : '';
          const email = emailValue ? String(emailValue) : '';
          const message = messageValue ? String(messageValue) : '';
          const gdprConsent = formData.get('gdpr_consent') === 'on';
          const projectTypeValue = formData.get('project_type');
          const projectType = projectTypeValue ? String(projectTypeValue) : '';

          const nameValidation = validateName(name);
          const emailValidation = validateEmail(email);
          const messageValidation = validateMessage(message);

          let hasErrors = false;

          if (nameValidation) {
            if (nameError && nameInput) {
              nameError.textContent = nameValidation;
              nameError.classList.remove('hidden');
              nameInput.classList.add('border-red-500');
              nameInput.classList.remove('border-green-500');
            }
            hasErrors = true;
          }

          if (emailValidation) {
            if (emailError && emailInput) {
              emailError.textContent = emailValidation;
              emailError.classList.remove('hidden');
              emailInput.classList.add('border-red-500');
              emailInput.classList.remove('border-green-500');
            }
            hasErrors = true;
          }

          if (messageValidation) {
            if (messageError && messageInput) {
              messageError.textContent = messageValidation;
              messageError.classList.remove('hidden');
              messageInput.classList.add('border-red-500');
              messageInput.classList.remove('border-green-500');
            }
            hasErrors = true;
          }

          if (!gdprConsent) {
            if (gdprError) {
              gdprError.textContent = 'You must agree to the Privacy Policy to submit this form.';
              gdprError.classList.remove('hidden');
            }
            if (gdprCheckbox) {
              gdprCheckbox.classList.add('ring-2', 'ring-red-500');
            }
            hasErrors = true;
          }

          if (hasErrors) {
            submitButton.disabled = false;
            buttonText?.classList.remove('hidden');
            buttonLoader?.classList.add('hidden');
            return;
          }

          submitButton.disabled = true;
          buttonText?.classList.add('hidden');
          buttonLoader?.classList.remove('hidden');
          successMessage?.classList.add('hidden');
          errorMessage?.classList.add('hidden');

          try {
            const response = await fetch('/api/contact', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name, email, message, gdprConsent, projectType }),
            });

            const data = await response.json();

            if (response.ok && data.success) {
              if (successMessage) {
                successMessage.classList.remove('hidden');
                successMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }

              form.reset();

              // Reset project type tags
              projectTypeTags.forEach((t) => {
                t.classList.remove('tag-active', 'border-cyan-400', 'bg-cyan-400/10', 'text-cyan-300');
                t.classList.add('border-gray-600/50', 'bg-gray-800/50', 'text-gray-300');
              });
              if (projectTypeInput) projectTypeInput.value = '';

              nameError?.classList.add('hidden');
              nameInput?.classList.remove('border-red-500', 'border-green-500');
              emailError?.classList.add('hidden');
              emailInput?.classList.remove('border-red-500', 'border-green-500');
              messageError?.classList.add('hidden');
              messageInput?.classList.remove('border-red-500', 'border-green-500');

              if (gdprError) {
                gdprError.classList.add('hidden');
                gdprCheckbox?.classList.remove('ring-2', 'ring-red-500');
              }

              if (messageCounter) {
                messageCounter.textContent = '0 / 1000';
                messageCounter.classList.remove('text-yellow-400');
                messageCounter.classList.add('text-gray-400');
              }

              window.gtag?.('event', 'form_submission', {
                form_type: 'contact',
                submission_status: 'success',
              });

              setTimeout(() => successMessage?.classList.add('hidden'), 10000);
            } else {
              throw new Error(data.message || 'Error sending message');
            }
          } catch (error) {
            console.error('Form submission error:', error);
            const errorMsg =
              error instanceof Error
                ? error.message
                : 'Please try again or send me an email directly at screatives.info@gmail.com';
            if (errorText) errorText.textContent = errorMsg;
            if (errorMessage) {
              errorMessage.classList.remove('hidden');
              errorMessage.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            window.gtag?.('event', 'form_submission', {
              form_type: 'contact',
              submission_status: 'error',
            });
          } finally {
            submitButton.disabled = false;
            buttonText?.classList.remove('hidden');
            buttonLoader?.classList.add('hidden');
          }
        });

        // Character counter
        if (messageInput && messageCounter) {
          const updateCounter = () => {
            const length = messageInput.value.length;
            const maxLength = messageInput.maxLength || 1000;
            messageCounter.textContent = `${length} / ${maxLength}`;
            if (length > maxLength * 0.9) {
              messageCounter.classList.add('text-yellow-400');
              messageCounter.classList.remove('text-gray-400');
            } else {
              messageCounter.classList.remove('text-yellow-400');
              messageCounter.classList.add('text-gray-400');
            }
          };
          messageInput.addEventListener('input', updateCounter);
          updateCounter();
        }

        // Real-time validation — name
        if (nameInput && nameError) {
          const applyNameValidation = () => {
            const error = validateName(nameInput.value);
            if (error) {
              nameError.textContent = error;
              nameError.classList.remove('hidden');
              nameInput.classList.add('border-red-500');
              nameInput.classList.remove('border-green-500');
            } else {
              nameError.classList.add('hidden');
              nameInput.classList.remove('border-red-500');
              nameInput.classList.add('border-green-500');
            }
          };

          nameInput.addEventListener('blur', applyNameValidation);
          nameInput.addEventListener('input', () => {
            if (nameInput.value.trim().length > 0) {
              applyNameValidation();
            } else {
              nameError.classList.add('hidden');
              nameInput.classList.remove('border-red-500', 'border-green-500');
            }
          });
        }

        // Real-time validation — email
        if (emailInput && emailError) {
          const applyEmailValidation = () => {
            const error = validateEmail(emailInput.value);
            if (error) {
              emailError.textContent = error;
              emailError.classList.remove('hidden');
              emailInput.classList.add('border-red-500');
              emailInput.classList.remove('border-green-500');
            } else {
              emailError.classList.add('hidden');
              emailInput.classList.remove('border-red-500');
              emailInput.classList.add('border-green-500');
            }
          };

          emailInput.addEventListener('blur', applyEmailValidation);
          emailInput.addEventListener('input', () => {
            if (emailInput.value.trim().length > 0) {
              applyEmailValidation();
            } else {
              emailError.classList.add('hidden');
              emailInput.classList.remove('border-red-500', 'border-green-500');
            }
          });
        }

        // Real-time validation — message
        if (messageInput && messageError) {
          const applyMessageValidation = () => {
            const error = validateMessage(messageInput.value);
            if (error) {
              messageError.textContent = error;
              messageError.classList.remove('hidden');
              messageInput.classList.add('border-red-500');
              messageInput.classList.remove('border-green-500');
            } else {
              messageError.classList.add('hidden');
              messageInput.classList.remove('border-red-500');
              messageInput.classList.add('border-green-500');
            }
          };

          messageInput.addEventListener('blur', applyMessageValidation);
          messageInput.addEventListener('input', () => {
            if (messageInput.value.trim().length > 0) {
              applyMessageValidation();
            } else {
              messageError.classList.add('hidden');
              messageInput.classList.remove('border-red-500', 'border-green-500');
            }
          });
        }

        // Real-time validation — GDPR checkbox
        if (gdprCheckbox && gdprError) {
          gdprCheckbox.addEventListener('change', () => {
            if (gdprCheckbox.checked) {
              gdprError.classList.add('hidden');
              gdprCheckbox.classList.remove('ring-2', 'ring-red-500');
            } else {
              gdprError.textContent = 'You must agree to the Privacy Policy to submit this form.';
              gdprError.classList.remove('hidden');
              gdprCheckbox.classList.add('ring-2', 'ring-red-500');
            }
          });
        }
      });
    </script>

  </div>

  <Footer />
</Layout>
